{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "vitest.setup.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
